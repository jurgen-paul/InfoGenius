{
  "entities": {
    "userProfile": {
      "title": "UserProfile",
      "description": "User profile containing public sign-in info",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "infographic": {
      "title": "Infographic",
      "description": "Information about a generated infographic saved in the database",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "data": { "type": "string", "description": "Base64 data URL of the image" },
        "prompt": { "type": "string" },
        "timestamp": { "type": "integer" },
        "level": { "type": "string", "enum": ["Elementary", "High School", "College", "Expert"] },
        "style": { "type": "string", "enum": ["Default", "Minimalist", "Realistic", "Cartoon", "Vintage", "Futuristic", "3D Render", "Sketch"] },
        "language": { "type": "string", "enum": ["English", "Spanish", "French", "German", "Mandarin", "Japanese", "Hindi", "Arabic", "Portuguese", "Russian"] },
        "imagePrompt": { "type": "string" },
        "originalTopic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "data", "prompt", "timestamp", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/infographics/{infographicId}": {
      "schema": "infographic",
      "description": "Infographics generated by and saved for specific logged-in users"
    }
  }
}
