rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (Default Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATION BLUEPRINTS ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'createdAt']) 
        && data.keys().size() <= 5
        && data.email is string 
        && data.email.size() <= 200
        && data.createdAt is timestamp
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 150))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    function isValidInfographic(data) {
      return data.keys().hasAll(['id', 'data', 'prompt', 'timestamp', 'createdAt'])
        && data.keys().size() <= 10
        && data.id is string
        && isValidId(data.id)
        && data.data is string
        && data.data.size() <= 1048576  // 1MB limit for Firestore document body
        && data.prompt is string
        && data.prompt.size() <= 5000
        && data.timestamp is int
        && data.createdAt is timestamp
        && (data.level == null || (data.level is string && data.level.size() <= 30))
        && (data.style == null || (data.style is string && data.style.size() <= 30))
        && (data.language == null || (data.language is string && data.language.size() <= 35))
        && (data.imagePrompt == null || (data.imagePrompt is string && data.imagePrompt.size() <= 5000))
        && (data.originalTopic == null || (data.originalTopic is string && data.originalTopic.size() <= 500));
    }

    // --- COLLECTION RULE DEFINITIONS ---

    // Standard Users collection
    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isOwner(userId);
      
      // Users can only create or update their own profile with correct validation
      allow create: if isOwner(userId) 
        && isEmailVerified()
        && isValidUserProfile(incoming()) 
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isEmailVerified()
        && isValidUserProfile(incoming())
        // Keep createdAt immutable during updates
        && incoming().createdAt == existing().createdAt;
    }

    // Infographics sub-collection
    match /users/{userId}/infographics/{infographicId} {
      // Mandatory validation of the path variable ID to protect against path poisoning
      allow get: if isOwner(userId) && isValidId(infographicId);
      
      // Enforce owner verification for list queries without get lookups (cheap & secure O(1) checks)
      allow list: if isOwner(userId);

      allow create: if isOwner(userId)
        && isEmailVerified()
        && isValidId(infographicId)
        && isValidInfographic(incoming())
        && incoming().createdAt == request.time;

      allow update: if isOwner(userId)
        && isEmailVerified()
        && isValidId(infographicId)
        && isValidInfographic(incoming())
        // Restrict immutable fields from being modified
        && incoming().id == existing().id
        && incoming().createdAt == existing().createdAt;

      allow delete: if isOwner(userId);
    }
  }
}
